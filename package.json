{
  "name": "green-todo",
  "version": "1.0.0",
  "description": "A refreshing daily todo app with satisfying animations",
  "main": "main.js",
  "author": "Xiobio",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.xiobio.green-todo",
    "productName": "Green Todo",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "zh_CN",
      "en"
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "app.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true,
        "NSHighResolutionCapable": true
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "shortcutName": "Green Todo"
    },
    "portable": {
      "artifactName": "GreenTodo-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1"
  }
}
